# Postgres connection string.
# On Vercel: add the "Postgres" storage integration (Storage tab in your project) -
# it auto-injects POSTGRES_URL into your environment, you don't need to set this manually there.
# For local development, point this at a local or dev Postgres instance.
POSTGRES_URL=postgres://user:password@localhost:5432/event_checkin

# Secret used to sign session JWTs. Generate a random string, e.g.:
#   openssl rand -base64 32
# Set this in Vercel's Environment Variables for Production/Preview - do NOT leave the default.
JWT_SECRET=replace-this-with-a-long-random-string

# OPTIONAL - enables a free external scheduler (or Vercel Pro cron) to trigger
# "Fetch latest from Google Sheet" automatically, even when no admin has the app open.
# Without this, auto-fetch still runs every 60s as long as an admin keeps the Import
# page open in a browser tab - this just makes it work unattended too. Any long random
# string works; generate one with: openssl rand -base64 24
CRON_SECRET=replace-this-with-a-long-random-string

# OPTIONAL - only needed for the "Push results to Google Sheets" feature.
# Fetching registrants FROM a sheet (the "Fetch latest" button) does NOT need these -
# it just reads a public CSV export link, no credentials required.
#
# To enable pushing results back to a sheet:
#   1. Create a Google Cloud project, enable the "Google Sheets API"
#   2. Create a Service Account, download its JSON key
#   3. Share your target Google Sheet with the service account's email as an Editor
#   4. Set these two values from the downloaded JSON:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
